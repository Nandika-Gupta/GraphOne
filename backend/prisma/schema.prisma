// GraphOne — Prisma schema
// Supabase PostgreSQL. Normalized models for the AI-intelligence graph.
// Run:  prisma migrate dev  →  prisma generate  →  npm run db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────
enum FundingStage {
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  SERIES_D
  SERIES_E
  GROWTH
  IPO
}

enum InvestorType {
  VC
  ANGEL
  ACCELERATOR
  CORPORATE
  GROWTH_EQUITY
  PE
  SOVEREIGN
}

enum RelationshipType {
  COMPETITOR
  ACQUISITION
  PARTNERSHIP
  SUBSIDIARY
  INTEGRATION
}

// ─────────────────────────────────────────────────────────────
// Company
// ─────────────────────────────────────────────────────────────
model Company {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  legalName    String?
  tagline      String?
  description  String?
  website      String?
  logoUrl      String?
  hqLocation   String?
  foundedYear  Int?
  employeeCount Int?
  employeeGrowthPct Float? @default(0) // trailing-12-month headcount growth
  isUnicorn    Boolean  @default(false)
  isClaimed    Boolean  @default(false)
  valuationUsd BigInt?
  totalRaisedUsd BigInt? @default(0)

  // ── Scoring / freshness (required by spec) ──
  growthScore          Float    @default(0)   // 0–100 composite
  dataConfidenceScore  Float    @default(0.5) // 0–1, completeness/recency of data
  trendingScore        Float    @default(0)   // computed by TrendingScoreService, cached
  lastScrapedAt        DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category     Category? @relation(fields: [categoryId], references: [id])
  categoryId   String?

  fundingRounds FundingRound[]
  products      Product[]
  founders      FounderCompany[]
  newsArticles  NewsArticle[]
  tags          CompanyTag[]
  relationsFrom CompanyRelationship[] @relation("RelFrom")
  relationsTo   CompanyRelationship[] @relation("RelTo")

  @@index([trendingScore(sort: Desc)])
  @@index([growthScore(sort: Desc)])
  @@index([categoryId])
  @@index([isUnicorn])
}

// ─────────────────────────────────────────────────────────────
// Investor
// ─────────────────────────────────────────────────────────────
model Investor {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  type         InvestorType @default(VC)
  description  String?
  website      String?
  logoUrl      String?
  hqLocation   String?
  foundedYear  Int?
  isVerified   Boolean      @default(false)

  // ── Required by spec ──
  avgCheckSizeUsd BigInt?    // typical check size
  fundNumber      Int?       // current fund (e.g. Fund VII -> 7)

  aumUsd        BigInt?
  thesis        String?
  stageFocus    FundingStage[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  investments  FundingRoundInvestor[]
  collections  InvestorCollectionItem[]

  @@index([type])
}

// ─────────────────────────────────────────────────────────────
// Founder
// ─────────────────────────────────────────────────────────────
model Founder {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  title       String?
  bio         String?
  avatarUrl   String?
  linkedinUrl String?
  twitterUrl  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies   FounderCompany[]
}

model FounderCompany {
  founder    Founder @relation(fields: [founderId], references: [id], onDelete: Cascade)
  founderId  String
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId  String
  role       String? // "CEO & Co-founder"
  isCurrent  Boolean @default(true)

  @@id([founderId, companyId])
  @@index([companyId])
}

// ─────────────────────────────────────────────────────────────
// FundingRound
// ─────────────────────────────────────────────────────────────
model FundingRound {
  id          String       @id @default(cuid())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  stage       FundingStage
  amountUsd   BigInt
  valuationUsd BigInt?
  announcedAt DateTime
  source      String?

  createdAt   DateTime @default(now())

  investors   FundingRoundInvestor[]

  @@index([companyId])
  @@index([announcedAt(sort: Desc)])
}

model FundingRoundInvestor {
  round      FundingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId    String
  investor   Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  investorId String
  isLead     Boolean      @default(false)

  @@id([roundId, investorId])
  @@index([investorId])
}

// ─────────────────────────────────────────────────────────────
// Product
// ─────────────────────────────────────────────────────────────
model Product {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  tagline     String?
  description String?
  url         String?
  logoUrl     String?
  category    String?
  upvotes     Int     @default(0)
  commentCount Int    @default(0)
  launchedAt  DateTime?

  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([upvotes(sort: Desc)])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// NewsArticle
// ─────────────────────────────────────────────────────────────
model NewsArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String?
  url         String
  source      String?
  imageUrl    String?
  publishedAt DateTime
  sentiment   Float?   @default(0) // -1..1
  viewCount   Int      @default(0)

  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId   String?

  createdAt   DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([companyId])
}

// ─────────────────────────────────────────────────────────────
// Tag / Category
// ─────────────────────────────────────────────────────────────
model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  colorHex  String?
  companies Company[]
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  companies CompanyTag[]
}

model CompanyTag {
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([companyId, tagId])
}

// ─────────────────────────────────────────────────────────────
// CompanyRelationship — the ecosystem graph edges
// ─────────────────────────────────────────────────────────────
model CompanyRelationship {
  id         String           @id @default(cuid())
  from       Company          @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  fromId     String
  to         Company          @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)
  toId       String
  type       RelationshipType
  weight     Float            @default(1)
  note       String?

  @@unique([fromId, toId, type])
  @@index([fromId])
  @@index([toId])
}

// ─────────────────────────────────────────────────────────────
// Investor collections (editorial groupings)
// ─────────────────────────────────────────────────────────────
model InvestorCollection {
  id      String                   @id @default(cuid())
  slug    String                   @unique
  title   String
  blurb   String?
  items   InvestorCollectionItem[]
}

model InvestorCollectionItem {
  collection   InvestorCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  investor     Investor           @relation(fields: [investorId], references: [id], onDelete: Cascade)
  investorId   String

  @@id([collectionId, investorId])
}
